# Copy to .env and fill in. NEVER commit the real .env.

# --- Core ---
TELEGRAM_TOKEN=            # from @BotFather
ALLOWED_USERS=            # comma-separated Telegram user IDs allowed to use the bot
TELEGRAM_CHAT_ID=         # your chat id for proactive notifications

# --- Service keys (all optional) ---
BRAVE_API_KEY=
GITHUB_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# --- Google accounts (Gmail / Drive / Calendar) ---
# Aliases, comma-separated, first = default. Authorize each:
#   python credentials/google_auth.py <alias>
GOOGLE_ACCOUNTS=personal
# Optional: map full emails to aliases so tools can resolve either.
# GOOGLE_EMAIL_MAP=me@gmail.com:personal,me@company.com:work

# --- Telegram user accounts (MTProto, https://my.telegram.org) ---
# Aliases, comma-separated, first = default. For each alias FOO add
# TELEGRAM_FOO_API_ID / _API_HASH / _PHONE, then:
#   python credentials/telegram_auth.py <alias>
TELEGRAM_ACCOUNTS=
# TELEGRAM_PERSONAL_API_ID=
# TELEGRAM_PERSONAL_API_HASH=
# TELEGRAM_PERSONAL_PHONE=+10000000000

# --- Misc ---
WHISPER_MODEL=small               # faster-whisper model for voice transcription
# VAULT_DIR=~/Documents/Vault     # Obsidian vault location (optional override)
# MCP_CONFIG_PATH=~/.claude/mcp.json
